src/pages/login.tsx

import { useState } from "react";
import { supabase } from "../lib/supabase";
import { useRouter } from "next/router";

export default function Login() {
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const router = useRouter();

  async function handleLogin() {
    const { error } = await supabase.auth.signInWithPassword({ email, password });
    if (!error) router.push("/dashboard");
  }

  async function handleSignUp() {
    const { error } = await supabase.auth.signUp({ email, password });
    if (!error) router.push("/dashboard");
  }

  return (
    <main style={{ padding: 40 }}>
      <h1>Login / Register</h1>
      <input placeholder="Email" onChange={(e) => setEmail(e.target.value)} />
      <input type="password" placeholder="Password" onChange={(e) => setPassword(e.target.value)} />
      <button onClick={handleLogin}>Login</button>
      <button onClick={handleSignUp}>Register</button>
    </main>
  );
}
src/pages/dashboard.tsx

import { useEffect, useState } from "react";
import { supabase } from "../lib/supabase";
import { loadStripe } from "@stripe/stripe-js";

export default function Dashboard() {
  const [user, setUser] = useState<any>(null);
  const [accounts, setAccounts] = useState<any[]>([]);
  const [balance, setBalance] = useState(0);

  useEffect(() => {
    const sessionUser = supabase.auth.getSession();
    sessionUser.then(({ data }) => {
      if (data.session) setUser(data.session.user);
    });
    fetch("/api/get-balance")
      .then((r) => r.json())
      .then((d) => setBalance(d.balance || 0));
    fetch("/api/get-accounts")
      .then((r) => r.json())
      .then((d) => setAccounts(d || []));
  }, []);

  const handleConnectBank = async () => {
    const { client_secret } = await (await fetch("/api/create-link-session")).json();
    const stripe = await loadStripe(process.env.NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY!);
    if (stripe)
      stripe.collectFinancialConnectionsAccounts({ clientSecret: client_secret });
  };

  const handlePayout = async () => {
    const res = await fetch("/api/create-payout", {
      method: "POST",
      body: JSON.stringify({ userId: user.id, amount: balance })
    });
    const data = await res.json();
    alert("Payout started");
  };

  return (
    <main style={{ padding: 40 }}>
      <h1>QuincePay Dashboard</h1>
      <p>Balance: ${balance}</p>
      <button onClick={handleConnectBank}>Connect Bank</button>
      <button onClick={handlePayout}>Withdraw</button>

      <h2>Connected Accounts</h2>
      {accounts.map((a) => (
        <div key={a.id}>{a.bank_name} ****{a.last4}</div>
      ))}
    </main>
  );
}
